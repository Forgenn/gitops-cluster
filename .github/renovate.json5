{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':dependencyDashboard',
    ':separatePatchReleases',
    ':semanticCommits',
  ],
  timezone: 'Europe/Madrid',
  schedule: [
    'after 3am and before 6am on monday',
  ],
  labels: [
    'renovate',
  ],
  reviewers: [
    'Forgenn',
  ],
  commitMessagePrefix: 'chore(deps):',
  automergeType: 'branch',
  vulnerabilityAlerts: {
    enabled: true,
    labels: [
      'security',
    ],
    automerge: true,
    automergeType: 'branch',
  },
  packageRules: [
    {
      description: 'Ignore internal loomie images (managed by CI, not Renovate)',
      enabled: false,
      matchPackageNames: [
        '/^registry\\.monederobox\\.dev//',
      ],
    },
    {
      description: 'Lidarr nightly and Readarr develop are intentional floating tags',
      matchPackageNames: [
        'lscr.io/linuxserver/lidarr',
        'lscr.io/linuxserver/readarr',
      ],
      enabled: false,
    },
    {
      description: 'Core infrastructure requires manual review',
      matchPackageNames: [
        'argo-cd',
        'cert-manager',
        'external-secrets',
        'longhorn',
        'cloudnative-pg',
        'kube-prometheus-stack',
        'democratic-csi',
        'snapshot-controller',
        'gateway-helm',
        'volsync',
      ],
      automerge: false,
      automergeType: 'pr',
      labels: [
        'renovate',
        'core-infra',
      ],
      minimumReleaseAge: '3 days',
    },
    {
      description: 'Automerge helm chart patch updates',
      matchManagers: [
        'kustomize',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
    },
    {
      description: 'PR for helm chart minor updates',
      matchManagers: [
        'kustomize',
      ],
      matchUpdateTypes: [
        'minor',
      ],
      automerge: false,
      automergeType: 'pr',
      labels: [
        'renovate',
        'helm-minor',
      ],
    },
    {
      description: 'PR for helm chart major updates, low priority',
      matchManagers: [
        'kustomize',
      ],
      matchUpdateTypes: [
        'major',
      ],
      automerge: false,
      automergeType: 'pr',
      labels: [
        'renovate',
        'helm-major',
      ],
      prPriority: -1,
    },
    {
      description: 'Automerge Docker image patch updates in values files',
      matchManagers: [
        'helm-values',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
    },
    {
      description: 'PR for Docker image minor/major updates',
      matchManagers: [
        'helm-values',
      ],
      matchUpdateTypes: [
        'minor',
        'major',
      ],
      automerge: false,
      automergeType: 'pr',
    },
    {
      description: 'Automerge raw deployment image patch updates',
      matchManagers: [
        'custom.regex',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
    },
    {
      description: 'PR for raw deployment image minor/major updates',
      matchManagers: [
        'custom.regex',
      ],
      matchUpdateTypes: [
        'minor',
        'major',
      ],
      automerge: false,
      automergeType: 'pr',
    },
    {
      description: 'Group *arr suite updates into one PR',
      matchPackageNames: [
        'lscr.io/linuxserver/prowlarr',
        'lscr.io/linuxserver/qbittorrent',
      ],
      groupName: 'arr-suite',
      automerge: false,
      automergeType: 'pr',
    },
    {
      description: 'Group media app image updates',
      matchPackageNames: [
        'deluan/navidrome',
        'ghcr.io/suwayomi/suwayomi-server',
        'ghcr.io/kareadita/kavita',
      ],
      groupName: 'media-apps',
      automerge: false,
      automergeType: 'pr',
    },
    {
      description: 'Wait 2 days after release before raising a PR',
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      minimumReleaseAge: '2 days',
    },
  ],
  'helm-values': {
    managerFilePatterns: [
      '/infra/.+/values/.+\\.yaml$/',
    ],
  },
  customManagers: [
    {
      customType: 'regex',
      description: 'Docker image tags in raw Deployment manifests',
      managerFilePatterns: [
        '/infra/.+/deployment\\.yaml$/',
        '/infra/.+/navidrome-deployment\\.yaml$/',
      ],
      matchStrings: [
        'image:\\s+(?<depName>[a-z0-9._\\-/]+):(?<currentValue>[a-zA-Z0-9._\\-]+)',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
    },
    {
      customType: 'regex',
      description: 'CNPG postgresql image versions in cluster YAML files',
      managerFilePatterns: [
        '/infra/.+\\.yaml$/',
      ],
      matchStrings: [
        'imageName:\\s+(?<depName>ghcr\\.io/cloudnative-pg/postgresql):(?<currentValue>[a-zA-Z0-9._\\-]+)',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
    },
  ],
  ignorePaths: [
    // Bundled upstream chart files (contain non-ASCII in CRD templates / READMEs)
    'infra/cert-manager/charts/**',
    'infra/opencloud/charts/**',
    // Markdown docs with Unicode arrows/em-dashes - not dependency files
    '**/CLAUDE.md',
    '**/README.md',
    '**/docs/**',
    // Internal/generated paths
    '**/loomie-sandbox/**',
    '**/scripts/**',
    'infra/loomie/backend/**',
    'infra/loomie/frontend/**',
    'infra/loomie/sidecar/**',
  ],
}
